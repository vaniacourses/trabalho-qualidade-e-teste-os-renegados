            inputValor.sendKeys("300");

            WebElement selectForma = driver.findElement(By.id("formaPagemento"));
            selectForma.click();
            WebElement opcaoDebito = driver.findElement(By.id("debito-option"));
            opcaoDebito.click();

            WebElement inputConfirm = driver.findElement(By.id("confirmarCompra"));
            inputConfirm.clear();
            inputConfirm.sendKeys("1");

            WebElement btnComprar = driver.findElement(By.id("btn-compra"));
            ((JavascriptExecutor) driver).executeScript("arguments[0].click();", btnComprar);

            Thread.sleep(1000);
            double saldoAposCompra = capturarSaldoAtual();

            // 3. PAGAR FATURA
            navegarPara("nav-fatura");

            inputConta = wait.until(ExpectedConditions.visibilityOfElementLocated(By.id("numeroContaFatura")));
            inputConta.clear();
            inputConta.sendKeys("80414");

            inputValor = driver.findElement(By.id("valorFatura"));
