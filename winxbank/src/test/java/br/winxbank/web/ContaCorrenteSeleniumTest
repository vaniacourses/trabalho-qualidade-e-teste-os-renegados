/**
 * TESTES FUNCIONAIS COM SELENIUM - ContaCorrente
 * Testa comportamentos e fluxos funcionais completos através da interface web
 * 
 * Requer: 
 * - Servidor Spring Boot rodando em http://localhost:8080
 * - ChromeDriver configurado
 * - Dados de teste: CPF 11111111111
 */
@DisplayName("Testes Funcionais Selenium - ContaCorrente")
public class ContaCorrenteFuncionalSeleniumTest {

    private WebDriver driver;
    private WebDriverWait wait;
    private static final String BASE_URL = "http://localhost:8080";
    private static final String CPF_TESTE = "11111111111";
    private static final long TIMEOUT_SEGUNDOS = 10;
    private static final double DELTA = 1.0; // Margem para cálculos

    @BeforeEach
    void setupTest() {
        ChromeOptions options = new ChromeOptions();
        options.addArguments("--headless");
        options.addArguments("--disable-gpu");
        options.addArguments("--window-size=1920,1080");
        driver = new ChromeDriver(options);
        wait = new WebDriverWait(driver, Duration.ofSeconds(TIMEOUT_SEGUNDOS));
    }

    @AfterEach
    void teardown() {
        if (driver != null) {
            driver.quit();
        }
    }

    /**
     * Faz login no sistema
     */
    private void fazerLogin() {
        driver.get(BASE_URL);

        if (!driver.findElements(By.id("btn-logout")).isEmpty()) {
            driver.findElement(By.id("btn-logout")).click();
            wait.until(ExpectedConditions.visibilityOfElementLocated(By.id("cpfLogin")));
        }

        wait.until(ExpectedConditions.visibilityOfElementLocated(By.id("cpfLogin")))
                .sendKeys(CPF_TESTE);

        driver.findElement(By.id("btn-login")).click();
        wait.until(ExpectedConditions.visibilityOfElementLocated(By.id("metric-saldo")));
    }

    /**
     * Parse do saldo exibido na tela
     */
    private double parseSaldo(String textoSaldo) {
        String limpo = textoSaldo.replace("R$ ", "")
                .replace(".", "")
                .replace(",", ".");
        try {
            return Double.parseDouble(limpo);
        } catch (NumberFormatException e) {
            throw new IllegalArgumentException("Formato de saldo inválido: " + textoSaldo, e);
        }
    }

    /**
     * Aguarda e captura o saldo atual da tela
     */
    private double capturarSaldoAtual() {
        WebElement saldoElement = wait.until(ExpectedConditions.visibilityOfElementLocated(By.id("metric-saldo")));
        return parseSaldo(saldoElement.getText());
    }

    /**
     * Navega para uma seção específica
     */
    private void navegarPara(String navId) {
        WebElement nav = wait.until(ExpectedConditions.presenceOfElementLocated(By.id(navId)));
        ((JavascriptExecutor) driver).executeScript("arguments[0].click();", nav);
        Thread.sleep(500); // Pequena pausa para animação
    }

