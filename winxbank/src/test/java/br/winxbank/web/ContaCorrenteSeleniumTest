            assertTrue(saldoAposCompra < saldoInicial, "Saldo após compra deve ser menor");
            assertEquals(saldoInicial - 400.0, saldoAposFatura, DELTA, "Saldo final = inicial - 300 (compra) - 100 (fatura)");
