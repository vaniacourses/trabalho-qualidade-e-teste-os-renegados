        @Test
        @DisplayName("Fluxo: Cliente paga fatura simples")
        void fluxo_pagarFaturaSimples() throws InterruptedException {
            fazerLogin();

            double saldoAntes = capturarSaldoAtual();
            
            navegarPara("nav-fatura");

            WebElement inputConta = wait.until(ExpectedConditions.visibilityOfElementLocated(By.id("numeroContaFatura")));
            inputConta.clear();
            inputConta.sendKeys("80414");

            WebElement inputValor = driver.findElement(By.id("valorFatura"));
            inputValor.clear();
            inputValor.sendKeys("300");

            WebElement btnPagar = driver.findElement(By.id("btn-pagar-fatura"));
            ((JavascriptExecutor) driver).executeScript("arguments[0].click();", btnPagar);

            Thread.sleep(1000);

            double saldoDepois = capturarSaldoAtual();

            // Validação
            assertEquals(saldoAntes - 300.0, saldoDepois, DELTA, "Saldo deve reduzir em 300");
        }

